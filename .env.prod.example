# ERP back — prod 환경변수 템플릿. `cp .env.prod.example .env.prod` 후 실값 기입.
# .env.prod 는 gitignore(secret). config.py 의 필수 필드(URL/secret)는 누락 시 startup 실패.

# 앱
DEBUG=false
LOG_LEVEL=INFO

# CORS — prod FE(Next.js, Vercel) origin (comma-separated)
#   예: https://erp.medisolveai.com
CORS_ORIGINS=https://<ERP_FE_DOMAIN>

# PostgreSQL — mediness prod pg 공유 인스턴스의 erp database
#   같은 docker network(mediness-app_default) 내부 통신이라 host=mediness-pg, port=5432(컨테이너 내부).
#   <user>/<pw> = mediness prod POSTGRES_USER/PASSWORD (mediness .env.prod 와 동일).
#   ※ 사전: docker exec mediness-pg psql -U <user> -c "CREATE DATABASE erp;"
DATABASE_URL=postgresql+asyncpg://<DB_USER>:<DB_PASSWORD>@mediness-pg:5432/erp

# JWT — mediness prod 와 **동일** 공유 secret (토큰 로컬 HS256 검증). mediness .env.prod 의 JWT_SECRET 그대로.
JWT_SECRET=<MEDINESS_PROD_JWT_SECRET>
JWT_ALGORITHM=HS256

# mediness 인증 위임(login/refresh/logout 프록시) — prod mediness-back.
#   같은 network 내부: http://mediness-back:28080  /  외부 도메인이면: https://<mediness-prod-api>
MEDINESS_API_URL=http://mediness-back:28080

# Slack 워크플로우 webhook 공유 시크릿 (intake 출처 검증, SPEC-004). prod slack 워크플로우와 동일 토큰.
ERP_SLACK_WEBHOOK_SECRET=<PROD_SLACK_WEBHOOK_SECRET>

# 배포 이미지 태그 — CI(deploy.yml Step 3)가 자동 append(:latest 또는 롤백 SHA). 로컬은 생략 가능(기본 latest).
# IMAGE_TAG=latest
