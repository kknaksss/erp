# ERP back 환경변수 — 복사해서 .env 로 사용
DEBUG=true
LOG_LEVEL=INFO

# uvicorn 포트 = 28082 (mediness +2). 실행: uv run uvicorn app.main:app --port 28082
# (포트는 CLI 인자 — config 가 읽는 env 아님. 배포 환경은 system.md 참조)

# CORS — front origin (comma-separated)
CORS_ORIGINS=http://localhost:3000

# PostgreSQL (asyncpg) — 로컬 dev (로컬 postgres)
DATABASE_URL=postgresql+asyncpg://erp:erp@localhost:5432/erp
# 배포(home-server): postgresql+asyncpg://<user>@<home-server>:25433/erp (인스턴스 공유, erp database)

# mediness 인증 프록시 (로그인/리프레시/로그아웃 위임 대상)
MEDINESS_API_URL=http://localhost:28080

# JWT — mediness 와 동일한 공유 secret 주입 (HS256)
JWT_SECRET=change-me-in-prod

# Slack 워크플로우 webhook 공유 시크릿 — intake 출처 검증(SPEC-004 §검증).
# Slack 워크플로우가 webhook 바디 `token` 필드에 이 값을 실어 보내고 ERP 가 대조한다.
ERP_SLACK_WEBHOOK_SECRET=change-me-in-prod
